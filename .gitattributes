# Per-branch ownership: when the orchestrator merges main into an existing
# exact branch (to pick up orchestrator/workflow improvements), these files
# stay as-is on the branch. The `ours` merge driver is configured at runtime
# by update-branches.sh (`git config merge.ours.driver true`).
#
# Note: flake.nix is branch-owned because update-version rewrites the
# bencoding-flake URL in it (e.g. /v0.2 for kapowarr 1.3.x).
pin.nix     merge=ours
flake.lock  merge=ours
flake.nix   merge=ours
